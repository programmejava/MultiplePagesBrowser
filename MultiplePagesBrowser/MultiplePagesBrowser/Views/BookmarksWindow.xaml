<Window x:Class="MultiplePagesBrowser.Views.BookmarksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="书签管理" Width="600" Height="520"
        Background="#0F0F1A"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#161624"/>
            <Setter Property="Foreground" Value="#90CAF9"/>
            <Setter Property="BorderBrush" Value="#252540"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E2A3A"/>
                                <Setter Property="BorderBrush" Value="#3A7BD5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A7BD5"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#EF9A9A"/>
            <Setter Property="BorderBrush" Value="#3A1A1A"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🔖  书签管理" Foreground="#E0E0E0" FontSize="15" FontWeight="Bold"/>
            <TextBlock x:Name="TxtCount" Foreground="#607d8b" FontSize="12"
                       VerticalAlignment="Bottom" Margin="10,0,0,2"/>
        </StackPanel>

        <!-- 搜索框 -->
        <Border Grid.Row="1" Background="#0E0E1C" BorderBrush="#252540" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,8" Padding="8,0">
            <Grid>
                <TextBlock Text="🔍  搜索书签..." Foreground="#334455" FontSize="12"
                           VerticalAlignment="Center" IsHitTestVisible="False"
                           x:Name="SearchPlaceholder"/>
                <TextBox x:Name="SearchBox"
                         Background="Transparent" Foreground="#D0D8E8"
                         BorderThickness="0" Height="32" FontSize="12"
                         VerticalContentAlignment="Center" CaretBrush="#4FC3F7"
                         TextChanged="SearchBox_TextChanged"/>
            </Grid>
        </Border>

        <!-- 书签列表 -->
        <ListView x:Name="BookmarkList" Grid.Row="2"
                  Background="#0D0D1B" BorderBrush="#1A1A30" BorderThickness="1"
                  Foreground="#E0E0E0" FontSize="12"
                  SelectionMode="Single"
                  MouseDoubleClick="BookmarkList_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="标题" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" Foreground="#D0D8E8"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="地址" Width="270">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Url}" Foreground="#90CAF9"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Url}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="添加时间" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AddedAt, StringFormat={}{0:MM-dd HH:mm}}"
                                           Foreground="#607d8b"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ContextMenu>
                <ContextMenu Background="#0D0D1B" BorderBrush="#252540">
                    <MenuItem Header="在当前格子打开" Click="CtxOpen_Click"
                              Foreground="#D0D8E8" Background="#0D0D1B"/>
                    <MenuItem Header="在新格子打开" Click="CtxOpenNew_Click"
                              Foreground="#D0D8E8" Background="#0D0D1B"/>
                    <Separator/>
                    <MenuItem Header="删除此书签" Click="CtxDelete_Click"
                              Foreground="#EF9A9A" Background="#0D0D1B"/>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>

        <!-- 底部按钮栏 -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Content="打开选中" Style="{StaticResource ActionBtn}"
                        Margin="0,0,8,0" Click="BtnOpen_Click"/>
                <Button Content="删除选中" Style="{StaticResource DangerBtn}"
                        Margin="0,0,8,0" Click="BtnDelete_Click"/>
                <Button Content="清空全部" Style="{StaticResource DangerBtn}"
                        Click="BtnClearAll_Click"/>
            </StackPanel>
            <Button Grid.Column="1" Content="关闭" Style="{StaticResource ActionBtn}"
                    Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
